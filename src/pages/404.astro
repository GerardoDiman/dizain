---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found">
  <section class="relative min-h-screen bg-surface flex items-center justify-center overflow-hidden">
    <!-- Blueprint Grid -->
    <div class="absolute inset-0 opacity-[0.04] grid-blueprint"></div>

    <div class="relative z-10 text-center px-6">
      <!-- Error Number -->
      <span class="block font-headline text-[clamp(8rem,25vw,16rem)] font-bold leading-none tracking-tighter text-primary/10">
        404
      </span>

      <!-- Message -->
      <h1 class="mt-4 font-headline text-2xl md:text-3xl font-bold uppercase tracking-tighter text-on-surface">
        Blueprint Not Found
      </h1>
      <p class="mt-3 font-body text-base text-outline max-w-md mx-auto">
        The technical drawing you're looking for doesn't exist in this archive.
      </p>

      <!-- CTA -->
      <a
        href="/"
        class="inline-block mt-8 bg-primary text-on-primary px-8 py-3.5 font-headline text-xs uppercase tracking-[0.2em] hover:bg-primary-container transition-colors"
      >
        Return to Archive
      </a>
    </div>
  </section>
</BaseLayout>
