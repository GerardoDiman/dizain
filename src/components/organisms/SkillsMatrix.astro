---
/**
 * SkillsMatrix — 4-column grid of skills by category.
 * Uses surface-container-high for the recessed "specs" look.
 */
import SectionNumber from '@components/atoms/SectionNumber.astro';
import SkillColumn from '@components/molecules/SkillColumn.astro';
import type { Skill, SkillCategory } from '@schemas/skill';
import { getLangFromUrl, useTranslations } from '@i18n/utils';

interface Props {
  skillsByCategory: Record<SkillCategory, Skill[]>;
}

const { skillsByCategory } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const columns: { title: string; category: SkillCategory }[] = [
  { title: t('skills.software'), category: 'software' },
  { title: t('skills.design'), category: 'design' },
  { title: t('skills.education'), category: 'education' },
  { title: t('skills.languages'), category: 'languages' },
];
---

<section
  class="relative bg-surface-container-high py-24 md:py-32"
  id="skills"
  aria-labelledby="specs-heading"
>
  <div class="max-w-7xl mx-auto px-6 md:px-8">
    <!-- Section Header -->
    <div class="relative mb-16 md:mb-20">
      <SectionNumber number="02" class="absolute -top-4 -left-2 md:-left-4" />
      <div class="relative z-10">
        <span class="font-label text-[0.6875rem] uppercase tracking-[0.3em] text-tertiary">
          {t('skills.label')}
        </span>
        <h2
          id="specs-heading"
          class="mt-2 font-headline text-3xl md:text-5xl font-bold uppercase tracking-tighter text-on-surface"
        >
          {t('skills.title')}
        </h2>
      </div>
    </div>

    <!-- Skills Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">
      {columns.map((col) => (
        <SkillColumn
          title={col.title}
          category={col.category}
          skills={skillsByCategory[col.category]}
        />
      ))}
    </div>
  </div>
</section>
