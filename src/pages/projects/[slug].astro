---
export const prerender = false;

/**
 * Project Detail — Dynamic page for each project case study.
 * Server-rendered on each request to reflect DB changes immediately.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionNumber from '@components/atoms/SectionNumber.astro';
import TechBadge from '@components/atoms/TechBadge.astro';
import VerticalText from '@components/atoms/VerticalText.astro';
import SpecBlock from '@components/molecules/SpecBlock.astro';
import { getProjectBySlug } from '@services/projects';
import type { Project } from '@schemas/project';

const { slug } = Astro.params;

let project: Project;
try {
  project = await getProjectBySlug(slug as string);
} catch {
  return Astro.redirect('/404');
}

const sortedImages = [...(project.project_images ?? [])].sort(
  (a, b) => a.sort_order - b.sort_order
);
const sortedSpecs = [...(project.project_specs ?? [])].sort(
  (a, b) => a.sort_order - b.sort_order
);
---

<BaseLayout
  title={`${project.title} — ARCHIVE.01`}
  description={project.subtitle ?? project.description.slice(0, 160)}
>
  <!-- Hero Banner -->
  <section class="relative bg-primary min-h-[60vh] flex items-end overflow-hidden pt-20">
    <div class="absolute inset-0 opacity-[0.07] grid-blueprint"></div>

    {project.hero_image_url && (
      <img
        src={project.hero_image_url}
        alt={project.title}
        class="absolute inset-0 w-full h-full object-cover opacity-30 mix-blend-luminosity"
      />
    )}

    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-8 pb-16 md:pb-20">
      <!-- Back link -->
      <a
        href="/#portfolio"
        class="inline-flex items-center gap-2 text-on-primary/50 font-label text-[0.6875rem] uppercase tracking-[0.2em] hover:text-on-primary/80 transition-colors mb-8"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
        Back to Portfolio
      </a>

      <!-- Title Block -->
      <div class="flex items-baseline gap-4 mb-4">
        <span class="font-headline text-5xl md:text-7xl font-bold text-on-primary/15">
          {project.sort_order.toString().padStart(2, '0')}
        </span>
        <h1 class="font-headline text-3xl md:text-5xl lg:text-6xl font-bold text-on-primary uppercase tracking-tighter">
          {project.title}
        </h1>
      </div>

      {project.subtitle && (
        <p class="font-body text-base md:text-lg text-on-primary/60 max-w-2xl">
          {project.subtitle}
        </p>
      )}

      <!-- Badges -->
      <div class="mt-6 flex flex-wrap gap-2">
        <TechBadge label={project.software} />
        {project.workbench && <TechBadge label={project.workbench} variant="secondary" />}
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-surface py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <!-- Description (left) -->
        <div class="lg:col-span-7 relative">
          <div class="absolute -left-8 top-0 hidden xl:block">
            <VerticalText text={project.software} />
          </div>

          <div class="mb-8">
            <span class="font-label text-[0.6875rem] uppercase tracking-[0.3em] text-tertiary">
              Project Overview
            </span>
            <h2 class="mt-2 font-headline text-2xl md:text-3xl font-bold uppercase tracking-tighter text-on-surface">
              Description
            </h2>
          </div>

          <p class="font-body text-base md:text-lg leading-relaxed text-on-surface-variant">
            {project.description}
          </p>
        </div>

        <!-- Specs (right) -->
        {sortedSpecs.length > 0 && (
          <div class="lg:col-span-5">
            <SpecBlock specs={sortedSpecs} />
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Image Gallery -->
  {sortedImages.length > 0 && (
    <section class="bg-surface-container py-20 md:py-28">
      <div class="max-w-7xl mx-auto px-6 md:px-8">
        <div class="mb-12">
          <span class="font-label text-[0.6875rem] uppercase tracking-[0.3em] text-tertiary">
            Visual Documentation
          </span>
          <h2 class="mt-2 font-headline text-2xl md:text-3xl font-bold uppercase tracking-tighter text-on-surface">
            Gallery
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
          {sortedImages.map((img) => (
            <figure class="bg-surface-container-lowest overflow-hidden tech-glow">
              <img
                src={img.image_url}
                alt={img.alt_text}
                class="w-full aspect-[16/10] object-cover"
                loading="lazy"
                decoding="async"
              />
              {img.caption && (
                <figcaption class="px-6 py-3 font-label text-[0.6875rem] text-outline uppercase tracking-[0.1em]">
                  {img.caption}
                </figcaption>
              )}
            </figure>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Bottom CTA -->
  <section class="bg-surface-container-high py-16">
    <div class="max-w-7xl mx-auto px-6 md:px-8 flex flex-col sm:flex-row justify-between items-center gap-6">
      <p class="font-headline text-sm uppercase tracking-[0.15em] text-on-surface">
        Interested in this type of work?
      </p>
      <a
        href="/#contact"
        class="bg-primary text-on-primary px-8 py-3.5 font-headline text-xs uppercase tracking-[0.2em] hover:bg-primary-container transition-colors"
      >
        Get in Touch
      </a>
    </div>
  </section>
</BaseLayout>
