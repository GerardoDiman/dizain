---
/**
 * HeroSection — Full-screen hero with blueprint grid overlay.
 * Inspired by the "Blueprint Archive" creative north star.
 */
import type { Profile } from '@schemas/profile';

interface Props {
  profile: Profile | null;
}

const { profile } = Astro.props;
const versionTag = profile?.version_tag ?? 'v.2024.01';
const title = profile?.title ?? 'Mechanical Design Engineer';
---

<section
  class="relative min-h-screen bg-primary flex items-end overflow-hidden"
  id="hero"
  aria-label="Hero section"
>
  <!-- Blueprint Grid Overlay -->
  <div class="absolute inset-0 opacity-[0.07] grid-blueprint"></div>

  <!-- Decorative vertical line -->
  <div class="absolute left-[10%] top-0 bottom-0 w-px bg-on-primary/10 hidden lg:block" aria-hidden="true"></div>
  <div class="absolute right-[10%] top-0 bottom-0 w-px bg-on-primary/10 hidden lg:block" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-8 pb-16 md:pb-24 pt-32">
    <!-- Top label -->
    <div class="mb-6 md:mb-8">
      <span class="inline-block font-label text-[0.6875rem] text-on-primary/60 uppercase tracking-[0.4em] border border-on-primary/20 px-4 py-1.5">
        {title}
      </span>
    </div>

    <!-- Main Heading -->
    <h1 class="text-[clamp(3.5rem,12vw,10rem)] font-headline font-bold text-on-primary leading-[0.85] tracking-tighter uppercase max-w-5xl">
      Precision<br />Archive
    </h1>

    <!-- Subline -->
    <p class="mt-6 md:mt-8 text-on-primary/60 font-body text-base md:text-lg max-w-xl leading-relaxed">
      Engineering solutions with meticulous attention to detail. CAD-driven design portfolio.
    </p>

    <!-- Meta bar -->
    <div class="mt-8 md:mt-12 flex flex-wrap gap-4 items-center">
      <span class="font-label text-[0.6875rem] text-on-primary/40 uppercase tracking-[0.2em] border border-on-primary/15 px-3 py-1">
        {versionTag}
      </span>
      <span class="font-label text-[0.6875rem] text-on-primary/40 uppercase tracking-[0.2em] border border-on-primary/15 px-3 py-1">
        Precision Archive
      </span>
      <span class="hidden md:inline-block font-label text-[0.6875rem] text-on-primary/40 uppercase tracking-[0.2em] border border-on-primary/15 px-3 py-1">
        Blueprint System
      </span>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2" aria-hidden="true">
      <span class="font-label text-[0.5rem] text-on-primary/30 uppercase tracking-[0.3em]">Scroll</span>
      <div class="w-px h-8 bg-on-primary/20 animate-pulse"></div>
    </div>
  </div>
</section>
