---
/**
 * SkillColumn — A vertical column in the skills matrix.
 * One column per category (Software, Education, Languages, Design).
 */
import type { Skill, SkillCategory } from '@schemas/skill';

interface Props {
  title: string;
  category: SkillCategory;
  skills: Skill[];
}

const { title, category, skills } = Astro.props;

const categoryIcons: Record<SkillCategory, string> = {
  software: '⬡',
  education: '◈',
  languages: '◎',
  design: '△',
};
---

<div class="flex flex-col gap-4">
  <!-- Column Header -->
  <div class="flex items-center gap-2 mb-2">
    <span class="text-tertiary text-lg" aria-hidden="true">{categoryIcons[category]}</span>
    <h3 class="font-headline text-sm font-semibold uppercase tracking-[0.15em] text-on-surface">
      {title}
    </h3>
  </div>

  <!-- Skill List -->
  <ul class="flex flex-col gap-2.5" role="list">
    {skills.map((skill) => (
      <li class="flex items-center gap-2 text-sm font-body text-on-surface-variant">
        <span class="w-1 h-1 bg-tertiary/60 flex-shrink-0" aria-hidden="true"></span>
        {skill.label}
      </li>
    ))}
  </ul>
</div>
