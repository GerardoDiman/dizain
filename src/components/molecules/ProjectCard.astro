---
/**
 * ProjectCard — Portfolio case study card.
 * No borders (No-Line Rule). Uses surface-container-lowest to pop forward.
 */
import TechBadge from '@components/atoms/TechBadge.astro';
import VerticalText from '@components/atoms/VerticalText.astro';
import type { Project } from '@schemas/project';

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
const displayNumber = (index + 1).toString().padStart(2, '0');
---

<a
  href={`/projects/${project.slug}`}
  class="group relative block bg-surface-container-lowest tech-glow overflow-hidden transition-all duration-300 hover:-translate-y-1"
  id={`project-card-${project.slug}`}
>
  <!-- Vertical Annotation -->
  <div class="absolute left-3 top-1/2 -translate-y-1/2 z-10 hidden lg:block">
    <VerticalText text={project.software} />
  </div>

  <!-- Thumbnail -->
  <div class="relative aspect-[4/3] overflow-hidden bg-surface-container-high">
    {project.thumbnail_url ? (
      <img
        src={project.thumbnail_url}
        alt={project.title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <span class="font-headline text-6xl font-bold text-primary/10">{displayNumber}</span>
      </div>
    )}

    <!-- Overlay on hover -->
    <div class="absolute inset-0 bg-primary/0 group-hover:bg-primary/40 transition-colors duration-300 flex items-center justify-center">
      <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 font-headline text-on-primary text-xs uppercase tracking-[0.3em]">
        View Project
      </span>
    </div>
  </div>

  <!-- Content -->
  <div class="p-6 lg:p-8">
    <!-- Number + Title -->
    <div class="flex items-baseline gap-3 mb-2">
      <span class="font-headline text-2xl font-bold text-primary/20">{displayNumber}</span>
      <h3 class="font-headline text-lg font-semibold text-on-surface uppercase tracking-tight group-hover:text-primary transition-colors">
        {project.title}
      </h3>
    </div>

    <!-- Subtitle -->
    {project.subtitle && (
      <p class="text-sm text-outline font-body mb-4 line-clamp-2">
        {project.subtitle}
      </p>
    )}

    <!-- Software Badge -->
    <div class="flex flex-wrap gap-2">
      <TechBadge label={project.software} />
      {project.workbench && <TechBadge label={project.workbench} variant="secondary" />}
    </div>
  </div>
</a>
