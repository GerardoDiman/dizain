---
/**
 * BioSection — About the designer with asymmetric layout.
 * Description on the left, profile image bleeding to the right.
 */
import SectionNumber from '@components/atoms/SectionNumber.astro';
import VerticalText from '@components/atoms/VerticalText.astro';
import type { Profile } from '@schemas/profile';
import { getLangFromUrl, useTranslations } from '@i18n/utils';

interface Props {
  profile: Profile | null;
}

const { profile } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  class="relative bg-surface py-24 md:py-32 overflow-hidden"
  id="about"
  aria-labelledby="about-heading"
>
  <div class="max-w-7xl mx-auto px-6 md:px-8">
    <!-- Section Header -->
    <div class="relative mb-16 md:mb-20">
      <SectionNumber number="01" class="absolute -top-4 -left-2 md:-left-4" />
      <div class="relative z-10">
        <span class="font-label text-[0.6875rem] uppercase tracking-[0.3em] text-tertiary">
          {t('about.label')}
        </span>
        <h2
          id="about-heading"
          class="mt-2 font-headline text-3xl md:text-5xl font-bold uppercase tracking-tighter text-on-surface"
        >
          {t('about.title')}
        </h2>
      </div>
    </div>

    <!-- Asymmetric Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <!-- Bio Text (left) -->
      <div class="lg:col-span-8 relative">
        <!-- Vertical annotation -->
        <div class="absolute -left-8 top-0 hidden xl:block">
          <VerticalText text={t('about.vertical')} />
        </div>

        <div class="space-y-6 max-w-2xl">
          {profile?.bio && profile.bio.length > 0 ? (
            profile.bio.map((paragraph) => (
              <p class="font-body text-base md:text-lg leading-relaxed text-on-surface-variant">
                {paragraph}
              </p>
            ))
          ) : (
            <>
              <p class="font-body text-base md:text-lg leading-relaxed text-on-surface-variant">
                Mechanical Design Engineer with expertise in precision CAD modeling and engineering analysis. Specializing in complex assembly design using industry-standard tools.
              </p>
              <p class="font-body text-base md:text-lg leading-relaxed text-on-surface-variant">
                Committed to delivering solutions that balance form, function, and manufacturability.
              </p>
            </>
          )}
        </div>

        <!-- Contact Info -->
        {profile?.email && (
          <div class="mt-10 flex flex-wrap gap-4">
            <a
              href={`mailto:${profile.email}`}
              class="inline-flex items-center gap-2 bg-primary text-on-primary px-6 py-3 font-headline text-xs uppercase tracking-[0.2em] hover:bg-primary-container transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                <polyline points="22,6 12,13 2,6" />
              </svg>
              {t('about.contact')}
            </a>
            {profile.linkedin_url && (
              <a
                href={profile.linkedin_url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 border border-outline/40 text-on-surface px-6 py-3 font-headline text-xs uppercase tracking-[0.2em] hover:bg-surface-container-high transition-colors"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                  <rect x="2" y="9" width="4" height="12" />
                  <circle cx="4" cy="4" r="2" />
                </svg>
                LinkedIn
              </a>
            )}
            {profile.cv_url && (
              <a
                href={profile.cv_url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 border border-outline/40 text-on-surface px-6 py-3 font-headline text-xs uppercase tracking-[0.2em] hover:bg-surface-container-high transition-colors"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="7 10 12 15 17 10"/>
                  <line x1="12" x2="12" y1="15" y2="3"/>
                </svg>
                {t('about.cv')}
              </a>
            )}
          </div>
        )}
      </div>

      <!-- Profile Image (right) -->
      <div class="lg:col-span-4 relative flex justify-end">
        <div class="relative w-full max-w-[380px] aspect-[3/4] bg-surface-container-high overflow-hidden shadow-2xl">
          {profile?.profile_image_url ? (
            <img
              src={profile.profile_image_url}
              alt={profile.full_name}
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center">
              <span class="font-headline text-8xl font-bold text-primary/10">GD</span>
            </div>
          )}

          <!-- Image caption overlay -->
          <div class="absolute bottom-0 left-0 right-0 h-1/3 bg-gradient-to-t from-[#2d3d28] via-[#2d3d28]/70 to-transparent flex flex-col justify-end p-5 pb-4">
            <p class="font-headline text-sm text-white uppercase tracking-widest drop-shadow-sm">
              {profile?.full_name ?? 'Designer'}
            </p>
            <p class="font-label text-[0.6875rem] text-white/80 uppercase tracking-[0.1em] mt-1 drop-shadow-sm">
              {profile?.title ?? 'Mechanical Designer'}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
