---
export const prerender = false;

// Force refresh
import BaseLayout from "@layouts/BaseLayout.astro";
import SectionNumber from "@components/atoms/SectionNumber.astro";
import GhostDivider from "@components/atoms/GhostDivider.astro";
import { getProjectBySlug } from "@services/projects";
import { getProfile } from "@services/profile";
import type { ProjectSpec } from "@schemas/project";

const validLangs = ['es', 'en'];
type Params = { lang: string; slug: string };
const { slug, lang } = Astro.params as Params;
if (!lang || !validLangs.includes(lang)) return Astro.redirect('/404');

let project: any;
let profile: any;
try {
  [project, profile] = await Promise.all([
    getProjectBySlug(slug, lang),
    getProfile(lang)
  ]);
} catch {
  return Astro.redirect('/404');
}

if (!project) return Astro.redirect("/404");

const mainImage = project?.project_images?.find(img => img.is_hero)?.image_url || project?.project_images?.[0]?.image_url;
---

<BaseLayout 
  title={`${project.title} | Technical Specs`}
  linkedinUrl={profile?.linkedin_url}
>
  <article class="pt-32 pb-24">
    <!-- Breadcrumb / Back Navigation -->
    <nav class="container mx-auto px-6 mb-12">
      <a 
        href={`/${lang}/#projects`} 
        class="inline-flex items-center gap-2 group text-label-sm text-outline hover:text-primary transition-colors uppercase tracking-[0.2em]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-1"><path d="m15 18-6-6 6-6"/></svg>
        {lang === 'es' ? 'Volver a Proyectos' : 'Back to Projects'}
      </a>
    </nav>

    <!-- Header -->
    <header class="container mx-auto px-6 mb-16 md:mb-24">
      <div class="flex flex-col md:flex-row justify-between items-end gap-8">
        <div class="max-w-2xl">
          <SectionNumber number="01" />
          <h1 class="text-display-lg font-heading text-primary uppercase leading-none mb-4">
            {project.title}
          </h1>
          <p class="text-title-md text-tertiary font-mono tracking-widest uppercase">
            {project.subtitle}
          </p>
        </div>
        <div class="hidden md:block text-right">
          <p class="text-label-sm text-outline uppercase tracking-tighter">Project Hash</p>
          <p class="font-mono text-xs text-primary opacity-50">#{project.id.slice(0, 8)}</p>
        </div>
      </div>
    </header>

    <GhostDivider />

    <!-- Project Content: Description & Carousel -->
    <section class="container mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 my-16 items-start">
      <!-- Description (left) -->
      <div class="lg:col-span-5 space-y-8">
        <div class="relative">
          <div class="absolute -left-4 top-0 w-1 h-full bg-primary/10"></div>
          <p class="text-body-lg leading-relaxed text-on-surface-variant pl-6">
            {project.description}
          </p>
        </div>
        
        <div class="pt-8 border-t border-outline/10">
          <p class="text-label-sm text-tertiary uppercase tracking-widest mb-2">Main Workbench</p>
          <p class="font-headline text-lg text-primary uppercase">{project.workbench}</p>
        </div>
      </div>

      <!-- Carousel / Visual Archive (right) -->
      <div class="lg:col-span-7 relative group">
        <div class="relative aspect-video bg-surface-container overflow-hidden shadow-2xl">
          <!-- Main Carousel Container -->
          <div 
            id="carousel-container"
            class="flex overflow-x-auto snap-x snap-mandatory no-scrollbar h-full scroll-smooth"
          >
            {project.project_images?.map((img, i) => (
              <div class="flex-none w-full h-full snap-start relative">
                {img.image_url.endsWith('.mp4') ? (
                  <video 
                    src={img.image_url} 
                    controls 
                    muted 
                    loop 
                    class="w-full h-full object-cover"
                  />
                ) : (
                  <img 
                    src={img.image_url} 
                    alt={`Technical view ${i + 1}`}
                    class="w-full h-full object-cover"
                  />
                )}
                {/* Slide Counter */}
                <div class="absolute top-4 right-4 bg-black/50 backdrop-blur-md px-3 py-1 rounded-full text-[10px] text-white font-mono">
                  {i + 1} / {project.project_images?.length || 0}
                </div>
              </div>
            ))}
          </div>

          <!-- Navigation Arrows -->
          <button 
            id="prev-btn"
            class="absolute left-4 top-1/2 -translate-y-1/2 z-20 bg-surface/80 backdrop-blur-sm p-3 hover:bg-primary hover:text-on-primary transition-all duration-300 opacity-0 group-hover:opacity-100"
            aria-label="Previous slide"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          
          <button 
            id="next-btn"
            class="absolute right-4 top-1/2 -translate-y-1/2 z-20 bg-surface/80 backdrop-blur-sm p-3 hover:bg-primary hover:text-on-primary transition-all duration-300 opacity-0 group-hover:opacity-100"
            aria-label="Next slide"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
          
          <!-- Instructions hint -->
          <div class="absolute bottom-4 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 transition-opacity">
            <span class="bg-primary text-on-primary text-[10px] uppercase tracking-[0.2em] px-4 py-2">
              {lang === 'es' ? 'Explorar Archivo' : 'Explore Archive'}
            </span>
          </div>
        </div>
      </div>
    </section>

    <script>
      const container = document.getElementById('carousel-container');
      const prevBtn = document.getElementById('prev-btn');
      const nextBtn = document.getElementById('next-btn');

      if (container && prevBtn && nextBtn) {
        prevBtn.addEventListener('click', () => {
          container.scrollBy({ left: -container.clientWidth, behavior: 'smooth' });
        });

        nextBtn.addEventListener('click', () => {
          container.scrollBy({ left: container.clientWidth, behavior: 'smooth' });
        });
      }
    </script>

    <GhostDivider />

    <!-- Technical Specifications Block -->
    <section class="container mx-auto px-6 py-20">
      <div class="bg-surface-container-high relative overflow-hidden">
        <!-- Background watermark -->
        <div class="absolute right-0 top-0 text-display-lg opacity-5 font-heading pointer-events-none translate-x-1/4 -translate-y-1/4">
          SPECS
        </div>
        
        <div class="p-8 md:p-12 relative z-10">
          <h2 class="text-label-md font-heading text-primary uppercase mb-12 tracking-[0.4em] border-b border-primary/20 pb-4 inline-block">
            {lang === 'es' ? 'Ficha Técnica' : 'Technical Data Sheet'}
          </h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-x-12 gap-y-10">
            {project.project_specs?.map((spec: ProjectSpec) => (
              <div class="space-y-2">
                <p class="text-[10px] text-tertiary uppercase tracking-widest font-mono">{spec.label}</p>
                <p class="text-on-surface font-body font-medium">{spec.value}</p>
              </div>
            ))}
            <div class="space-y-2">
              <p class="text-[10px] text-tertiary uppercase tracking-widest font-mono">Core Software</p>
              <p class="text-on-surface font-body font-medium">{project.software}</p>
            </div>
            <div class="space-y-2">
              <p class="text-[10px] text-tertiary uppercase tracking-widest font-mono">Engineering ID</p>
              <p class="text-on-surface font-mono text-sm opacity-60">PRJ-{project.id.slice(0, 8).toUpperCase()}</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
