---
/**
 * ContactSection — CTA with contact form (React Island).
 * Blueprint grid background for visual continuity.
 */
import SectionNumber from '@components/atoms/SectionNumber.astro';
---

<section
  class="relative bg-primary py-24 md:py-32 overflow-hidden"
  id="contact"
  aria-labelledby="contact-heading"
>
  <!-- Blueprint Grid Overlay -->
  <div class="absolute inset-0 opacity-[0.05] grid-blueprint"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-8">
    <!-- Section Header -->
    <div class="relative mb-16 md:mb-20">
      <SectionNumber number={4} class="absolute -top-4 -left-2 md:-left-4 !text-on-primary/10" />
      <div class="relative z-10">
        <span class="font-label text-[0.6875rem] uppercase tracking-[0.3em] text-on-primary/50">
          Get in Touch
        </span>
        <h2
          id="contact-heading"
          class="mt-2 font-headline text-3xl md:text-5xl font-bold uppercase tracking-tighter text-on-primary"
        >
          Contact
        </h2>
      </div>
    </div>

    <!-- Contact Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
      <!-- Left: CTA Text -->
      <div class="flex flex-col justify-center">
        <p class="font-body text-base md:text-lg text-on-primary/70 leading-relaxed max-w-md">
          Interested in collaboration or have a project in mind? Let's discuss how precision engineering meets design excellence.
        </p>
        <div class="mt-8 flex flex-col gap-3">
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 text-on-primary/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
              <polyline points="22,6 12,13 2,6" />
            </svg>
            <span class="font-label text-[0.6875rem] text-on-primary/50 uppercase tracking-[0.15em]">
              Response within 24h
            </span>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 text-on-primary/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
              <polyline points="22 4 12 14.01 9 11.01" />
            </svg>
            <span class="font-label text-[0.6875rem] text-on-primary/50 uppercase tracking-[0.15em]">
              All inquiries welcome
            </span>
          </div>
        </div>
      </div>

      <!-- Right: Contact Form (React Island placeholder) -->
      <div id="contact-form-container">
        <form
          id="contact-form"
          class="flex flex-col gap-6"
          novalidate
        >
          <!-- Name -->
          <div class="flex flex-col gap-1.5">
            <label for="contact-name" class="font-label text-[0.6875rem] uppercase tracking-[0.1em] text-on-primary/50">
              Name
            </label>
            <input
              type="text"
              id="contact-name"
              name="name"
              required
              class="bg-on-primary/5 border-0 border-b border-on-primary/30 px-4 py-3 text-on-primary font-body text-sm placeholder:text-on-primary/20 focus:border-on-primary/60 focus:outline-none transition-colors"
              placeholder="Your full name"
            />
          </div>

          <!-- Email -->
          <div class="flex flex-col gap-1.5">
            <label for="contact-email" class="font-label text-[0.6875rem] uppercase tracking-[0.1em] text-on-primary/50">
              Email
            </label>
            <input
              type="email"
              id="contact-email"
              name="email"
              required
              class="bg-on-primary/5 border-0 border-b border-on-primary/30 px-4 py-3 text-on-primary font-body text-sm placeholder:text-on-primary/20 focus:border-on-primary/60 focus:outline-none transition-colors"
              placeholder="your@email.com"
            />
          </div>

          <!-- Company (optional) -->
          <div class="flex flex-col gap-1.5">
            <label for="contact-company" class="font-label text-[0.6875rem] uppercase tracking-[0.1em] text-on-primary/50">
              Company <span class="text-on-primary/20">(optional)</span>
            </label>
            <input
              type="text"
              id="contact-company"
              name="company"
              class="bg-on-primary/5 border-0 border-b border-on-primary/30 px-4 py-3 text-on-primary font-body text-sm placeholder:text-on-primary/20 focus:border-on-primary/60 focus:outline-none transition-colors"
              placeholder="Company name"
            />
          </div>

          <!-- Message -->
          <div class="flex flex-col gap-1.5">
            <label for="contact-message" class="font-label text-[0.6875rem] uppercase tracking-[0.1em] text-on-primary/50">
              Message
            </label>
            <textarea
              id="contact-message"
              name="message"
              rows="4"
              required
              class="bg-on-primary/5 border-0 border-b border-on-primary/30 px-4 py-3 text-on-primary font-body text-sm placeholder:text-on-primary/20 focus:border-on-primary/60 focus:outline-none transition-colors resize-none"
              placeholder="Describe your project or inquiry…"
            ></textarea>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="mt-2 bg-on-primary text-primary px-8 py-3.5 font-headline text-xs uppercase tracking-[0.2em] hover:bg-on-primary/90 transition-colors self-start"
          >
            Send Message
          </button>

          <!-- Status -->
          <div id="form-status" class="hidden font-label text-[0.6875rem] uppercase tracking-[0.1em]"></div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;

    const formData = new FormData(form);
    const payload = {
      name: formData.get('name') as string,
      email: formData.get('email') as string,
      company: formData.get('company') as string || undefined,
      message: formData.get('message') as string,
    };

    /* Basic validation */
    if (!payload.name || !payload.email || !payload.message) {
      status.textContent = '⚠ Please fill in all required fields.';
      status.className = 'font-label text-[0.6875rem] uppercase tracking-[0.1em] text-error-container';
      status.classList.remove('hidden');
      return;
    }

    if (payload.message.length < 10) {
      status.textContent = '⚠ Message must be at least 10 characters.';
      status.className = 'font-label text-[0.6875rem] uppercase tracking-[0.1em] text-error-container';
      status.classList.remove('hidden');
      return;
    }

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    try {
      /* Edge Function endpoint */
      const response = await fetch('https://2x69jnc5.functions.insforge.app/contact-form', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (response.ok) {
        status.textContent = '✓ Message sent successfully. Thank you!';
        status.className = 'font-label text-[0.6875rem] uppercase tracking-[0.1em] text-on-primary/60';
        status.classList.remove('hidden');
        form.reset();
      } else {
        throw new Error('Failed to send');
      }
    } catch {
      status.textContent = '✕ Failed to send. Please try again.';
      status.className = 'font-label text-[0.6875rem] uppercase tracking-[0.1em] text-error-container';
      status.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Message';
    }
  });
</script>
