---
/**
 * HeroSection — Full-screen hero with blueprint grid overlay.
 * Inspired by the "Blueprint Archive" creative north star.
 */
import type { Profile } from '@schemas/profile';

interface Props {
  profile: Profile | null;
}
import { getLangFromUrl, useTranslations } from '@i18n/utils';
import BlueprintCanvas from '@components/atoms/BlueprintCanvas';

const { profile } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const versionTag = profile?.version_tag ?? 'v.2024.01';

const title = profile?.title ?? 'Mechanical Design Engineer';
---

<section
  class="relative min-h-screen bg-primary flex items-center lg:items-end overflow-hidden"
  id="hero"
  aria-label="Hero section"
>
  <!-- Interactive 3D Background -->
  <div class="absolute inset-0 z-0">
    <BlueprintCanvas client:load />
    <div class="absolute inset-0 bg-gradient-to-b from-primary via-transparent to-primary/80 opacity-60"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-8 pt-32 pb-24 md:pb-24">
    <!-- Top label -->
    <div class="mb-6 md:mb-10 flex flex-col sm:flex-row items-start sm:items-center gap-4 entry-animate entry-delay-2">
      <span class="inline-block font-label text-[0.6875rem] text-on-primary/60 uppercase tracking-[0.4em] border border-on-primary/20 px-4 py-1.5">
        {title}
      </span>
      <a 
        href="#projects" 
        class="inline-block bg-primary border border-on-primary/40 text-on-primary px-8 py-3.5 font-headline uppercase tracking-[0.2em] text-[0.7rem] hover:bg-on-primary hover:text-primary transition-all"
      >
        {t('hero.cta')}
      </a>
    </div>

    <!-- Main Heading -->
    <h1 class="text-[clamp(2.75rem,14vw,10rem)] font-headline font-bold text-on-primary leading-[0.85] tracking-tighter uppercase max-w-5xl entry-animate entry-delay-3">
      {t('hero.title_1')}<br />{t('hero.title_2')}
    </h1>

    <!-- Subline -->
    <p class="mt-8 md:mt-10 text-on-primary/80 font-body text-base md:text-lg max-w-xl leading-relaxed entry-animate entry-delay-4">
      {t('hero.description')}
    </p>

    <!-- Meta bar -->
    <div class="mt-8 md:mt-12 flex flex-wrap gap-4 items-center entry-animate entry-delay-5">
      <span class="font-label text-[0.6875rem] text-on-primary/40 uppercase tracking-[0.2em] border border-on-primary/15 px-3 py-1">
        {versionTag}
      </span>
      <span class="font-label text-[0.6875rem] text-on-primary/40 uppercase tracking-[0.2em] border border-on-primary/15 px-3 py-1">
        {t('hero.version_tag')}
      </span>
      <span class="hidden md:inline-block font-label text-[0.6875rem] text-on-primary/40 uppercase tracking-[0.2em] border border-on-primary/15 px-3 py-1">
        {t('hero.system_tag')}
      </span>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2" aria-hidden="true">
      <span class="font-label text-[0.5rem] text-on-primary/30 uppercase tracking-[0.3em]">{t('hero.scroll')}</span>
      <div class="w-px h-8 bg-on-primary/20 animate-pulse"></div>
    </div>

  </div>
</section>
