---
import '../styles/global.css';
import Navbar from '@components/organisms/Navbar.astro';
import Footer from '@components/organisms/Footer.astro';
import TechnicalPreloader from '@components/atoms/TechnicalPreloader';

import { getLangFromUrl, useTranslations } from '@i18n/utils';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  linkedinUrl?: string;
  showPreloader?: boolean;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const {
  title,
  description = t('hero.description'),
  ogImage = '/og/default.png',
  linkedinUrl,
  showPreloader = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://dizain.vercel.app');
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl.href} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts (preload critical) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Dark Mode & Preload Check: Prevent FOUC and repetitive preloading -->
    <script is:inline>
      (function () {
        // Theme
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }

        // Preload check
        if (sessionStorage.getItem('dizain-preloaded')) {
          document.documentElement.classList.add('preloaded');
        }
      })();
    </script>
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>
  </head>

  <body class="bg-surface text-on-surface font-body selection:bg-primary/10 selection:text-primary">
    <!-- Technical Assembly Preloader -->
    {showPreloader && <TechnicalPreloader client:only="react" />}

    <Navbar linkedinUrl={linkedinUrl} />
    <main class="min-h-screen">
      <slot />
    </main>
    <Footer linkedinUrl={linkedinUrl} />

    <style is:global>
      /* Hide scrollbar during preloading */
      body.loading {
        overflow: hidden !important;
      }
      /* Hide preloader if already shown in session */
      .preloaded [data-preloader] {
        display: none !important;
      }
    </style>

    <script define:vars={{ showPreloader }}>
      const isPreloaded = sessionStorage.getItem('dizain-preloaded');
      
      if (showPreloader && !isPreloaded) {
        document.body.classList.add('loading');
        
        // Timeout fallback to ensure site is never stuck
        const timeout = setTimeout(() => {
          document.body.classList.remove('loading');
        }, 8000);

        window.addEventListener('site-loaded', () => {
          clearTimeout(timeout);
          document.body.classList.remove('loading');
          sessionStorage.setItem('dizain-preloaded', 'true');
        });
      }
    </script>
  </body>
</html>
