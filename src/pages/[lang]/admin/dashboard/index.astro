---
import AdminLayout from "@layouts/AdminLayout.astro";
import { supabase } from "@lib/supabase";
import { Plus, ExternalLink, Edit, MoreHorizontal, Circle, Globe } from "lucide-react";

const { lang = 'es' } = Astro.params;

// Fetch all projects for the dashboard list
const { data: projects, error } = await supabase
  .from("projects")
  .select("*")
  .order("sort_order", { ascending: true });

const { count: totalViews } = await supabase
  .from("page_views")
  .select("*", { count: 'exact', head: true });

if (error) {
  console.error("Error fetching projects:", error.message);
}

// Helper to extract translation for display
const t = (field: any) => {
  if (!field) return '';
  if (typeof field === 'string') return field;
  return field[lang] || field['es'] || Object.values(field)[0] || '';
};
---

<AdminLayout title="Dashboard de Proyectos">
  <div class="space-y-12 animate-in fade-in slide-in-from-bottom-4 duration-1000">
    <!-- Header Stats / Overview -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="bg-surface-container-low p-8 border-l-4 border-primary">
        <p class="text-[10px] font-label font-bold text-primary uppercase tracking-[0.2em] mb-2">Vistas Totales</p>
        <p class="text-4xl font-headline font-bold">{totalViews || 0}</p>
      </div>
      <div class="bg-surface-container-low p-8 border-l-4 border-secondary">
        <p class="text-[10px] font-label font-bold text-secondary uppercase tracking-[0.2em] mb-2">Total Proyectos</p>
        <p class="text-4xl font-headline font-bold">{projects?.length || 0}</p>
      </div>
      <div class="bg-surface-container-low p-8 border-l-4 border-tertiary">
        <p class="text-[10px] font-label font-bold text-tertiary uppercase tracking-[0.2em] mb-2">Publicados</p>
        <p class="text-4xl font-headline font-bold">{projects?.filter(p => p.is_published).length || 0}</p>
      </div>
      <div class="bg-surface-container-low p-8 border-l-4 border-outline">
        <p class="text-[10px] font-label font-bold text-secondary uppercase tracking-[0.2em] mb-2">Borradores</p>
        <p class="text-4xl font-headline font-bold">{projects?.filter(p => !p.is_published).length || 0}</p>
      </div>
    </div>

    <!-- Project Table -->
    <div class="bg-surface-container-lowest border border-outline-variant relative">
      <div class="p-8 border-b border-outline-variant flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-1 h-6 bg-primary"></div>
          <h3 class="font-headline font-bold uppercase tracking-tight">Archivo de Proyectos</h3>
        </div>
        <a 
          href={`/${lang}/admin/projects/new`} 
          class="bg-primary hover:bg-primary-container text-on-primary px-6 py-2 flex items-center gap-2 transition-all group"
        >
          <Plus className="w-4 h-4 transition-transform group-hover:rotate-90" />
          <span class="font-label text-[10px] font-bold uppercase tracking-widest">Añadir Proyecto</span>
        </a>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-surface-container-low border-b border-outline-variant">
              <th class="px-8 py-4 font-label text-[10px] font-bold text-secondary uppercase tracking-widest">ID / Título</th>
              <th class="px-8 py-4 font-label text-[10px] font-bold text-secondary uppercase tracking-widest">Estado</th>
              <th class="px-8 py-4 font-label text-[10px] font-bold text-secondary uppercase tracking-widest">Software</th>
              <th class="px-8 py-4 font-label text-[10px] font-bold text-secondary uppercase tracking-widest">Idiomas</th>
              <th class="px-8 py-4 font-label text-[10px] font-bold text-secondary uppercase tracking-widest text-right">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {projects?.map((project) => (
              <tr class="border-b border-outline-variant hover:bg-surface-container/30 transition-colors group">
                <td class="px-8 py-6">
                  <div class="flex flex-col">
                    <span class="text-sm font-bold font-headline uppercase tracking-tight">{t(project.title)}</span>
                    <span class="text-[9px] font-label text-secondary uppercase tracking-widest mt-1">/{project.slug}</span>
                  </div>
                </td>
                <td class="px-8 py-6">
                  <div class="flex items-center gap-2">
                    <Circle className={`w-2 h-2 fill-current ${project.is_published ? 'text-tertiary' : 'text-outline'}`} />
                    <span class={`text-[10px] font-label font-bold uppercase tracking-widest ${project.is_published ? 'text-tertiary' : 'text-secondary'}`}>
                      {project.is_published ? 'Publicado' : 'Borrador'}
                    </span>
                  </div>
                </td>
                <td class="px-8 py-6">
                  <span class="text-[10px] font-label text-on-surface-variant uppercase tracking-wider bg-surface-container px-2 py-1">
                    {t(project.software)}
                  </span>
                </td>
                <td class="px-8 py-6">
                  <div class="flex gap-1">
                    {project.title?.es && <span class="text-[8px] font-bold border border-outline-variant px-1 text-secondary uppercase">ES</span>}
                    {project.title?.en && <span class="text-[8px] font-bold border border-outline-variant px-1 text-secondary uppercase">EN</span>}
                  </div>
                </td>
                <td class="px-8 py-6 text-right">
                  <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                    <a 
                      href={`/${lang}/admin/projects/${project.id}`}
                      class="p-2 hover:bg-primary-container/20 text-primary transition-colors"
                      title="Editar"
                    >
                      <Edit className="w-4 h-4" />
                    </a>
                    <a 
                      href={`/${lang}/projects/${project.slug}`}
                      target="_blank"
                      class="p-2 hover:bg-tertiary-container/20 text-tertiary transition-colors"
                      title="Ver en Vivo"
                    >
                      <ExternalLink className="w-4 h-4" />
                    </a>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      
      {!projects?.length && (
        <div class="p-20 text-center">
          <p class="font-label text-xs text-secondary uppercase tracking-[0.3em]">No se encontraron proyectos en la base de datos</p>
        </div>
      )}
    </div>
  </div>
</AdminLayout>
